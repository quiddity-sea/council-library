{
    "name": "council-library/api",
    "description": "PHP REST API for the Council Library — sovereign memory architecture",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "monolog/monolog": "^3.5",
        "vlucas/phpdotenv": "^5.6",
        "php-di/slim-bridge": "^3.4"
    },
    "autoload": {
        "psr-4": {
            "CouncilLibrary\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8080 -t public",
        "test": "phpunit"
    }
}
